{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mareikeschomerus-ctrl/sIfA/blob/main/docs/sifa.schema.json",
  "title": "sIfA save file",
  "description": "Schema for a .sifa.json file produced by the 'Make your sIfA' tool — a Statement of Intellectual Fellowship and Accountability. Two kinds of file are valid: a full tool-state save ('sifa-tool-state', written by 💾 Save sIfA), and a portfolio-only save ('sifa-portfolio', written by 💾 Save Portfolio inside the portfolio panel). Both round-trip into the tool; portfolio-only files are merged into the existing portfolio on load rather than replacing the current draft.",

  "oneOf": [
    { "$ref": "#/$defs/fullState" },
    { "$ref": "#/$defs/portfolioOnly" }
  ],

  "$defs": {
    "fullState": {
      "title": "Full tool-state save",
      "description": "Captures the complete editable state of the tool: active role taxonomy, per-role contributor entries, optional portfolio of saved sIfAs, and the figure font choice. Written by the toolbar's 💾 Save sIfA action.",
      "type": "object",
      "required": ["version", "kind", "savedAt", "activeRoles", "taxonomyMode", "data"],
      "additionalProperties": false,
      "properties": {
        "version":      { "$ref": "#/$defs/version" },
        "kind":         { "type": "string", "const": "sifa-tool-state",
                          "description": "Discriminator marking this as a full tool-state save." },
        "savedAt":      { "$ref": "#/$defs/savedAt" },
        "activeRoles":  { "$ref": "#/$defs/activeRoles" },
        "taxonomyMode": { "$ref": "#/$defs/taxonomyMode" },
        "data": {
          "description": "Per-role data. Keys are role ids (matching activeRoles[].id). Roles present in activeRoles but absent from data are treated as empty.",
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/roleData" }
        },
        "portfolio":    { "$ref": "#/$defs/portfolio" },
        "figureFont":   { "$ref": "#/$defs/figureFont" }
      }
    },

    "portfolioOnly": {
      "title": "Portfolio-only save",
      "description": "A slimmer file that holds just the portfolio entries — useful for archiving or sharing a portfolio without the current draft. Loading this file MERGES its entries into the existing portfolio instead of replacing the whole state.",
      "type": "object",
      "required": ["version", "kind", "savedAt", "portfolio"],
      "additionalProperties": false,
      "properties": {
        "version": { "$ref": "#/$defs/version" },
        "kind":    { "type": "string", "const": "sifa-portfolio",
                     "description": "Discriminator marking this as a portfolio-only save." },
        "savedAt": { "$ref": "#/$defs/savedAt" },
        "portfolio": {
          "description": "Portfolio entries to merge into the loading tool's existing portfolio.",
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/portfolioEntry" }
        }
      }
    },

    "version": {
      "description": "Schema major version. Bumped only on incompatible changes; the tool refuses files whose version it does not recognise.",
      "type": "integer",
      "minimum": 1,
      "const": 1
    },

    "savedAt": {
      "description": "ISO 8601 timestamp recording when the file was saved. Informational; the tool does not rely on it for restore.",
      "type": "string",
      "format": "date-time"
    },

    "activeRoles": {
      "description": "Ordered list of the contributor roles in the table at the time of save. With the standard taxonomy this is the 14 CRediT roles; with a custom taxonomy this is the user's own list. The order here is the order rendered in the table and on the figure axes.",
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/role" }
    },

    "taxonomyMode": {
      "description": "Which taxonomy is in use. 'credit' = the 14 NISO CRediT roles. 'custom' = a user-defined taxonomy held in activeRoles.",
      "type": "string",
      "enum": ["credit", "custom"]
    },

    "portfolio": {
      "description": "Optional collection of saved sIfAs the user has bundled together (for example, to compare AI use across several papers). Each entry is a self-contained snapshot.",
      "type": "array",
      "items": { "$ref": "#/$defs/portfolioEntry" }
    },

    "figureFont": {
      "description": "Font family for the radar figure. The tool falls back to 'montserrat' if the value is missing or unknown.",
      "type": "string",
      "enum": ["montserrat", "georgia", "inter"]
    },

    "role": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "description": "Stable identifier. For CRediT roles this is the canonical snake_case form (e.g. 'data_curation', 'writing_review'). For custom roles the tool generates a slug.",
          "type": "string",
          "minLength": 1
        },
        "label": {
          "description": "Display label shown to the user (e.g. 'Data Curation', 'Writing – review & editing').",
          "type": "string",
          "minLength": 1
        },
        "def": {
          "description": "One-sentence definition of the role, shown in tooltips and embedded in the exported metadata. Required for CRediT roles; optional for custom roles.",
          "type": "string"
        },
        "bg":     { "$ref": "#/$defs/hexColour", "description": "Background colour for the role's table row." },
        "accent": { "$ref": "#/$defs/hexColour", "description": "Accent colour used for the role's label and figure axis." },
        "border": { "$ref": "#/$defs/hexColour", "description": "Border / hairline colour for the role's row." }
      }
    },

    "hexColour": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{3}([0-9A-Fa-f]{3})?$"
    },

    "contributor": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "description": "Contributor's display name. AI tools are listed as contributors here only when the author chooses to attribute the role to them by name; the more common pattern is to list humans here and record the AI tool in 'tool'.",
          "type": "string"
        },
        "level": {
          "description": "Engagement level for this contributor on this role. Sole = only this contributor on the row. Lead = principal owner; others on the row are Support. Equal = two-or-more contributors share the role equally. Support = secondary involvement; not valid as the sole level on a row.",
          "type": ["string", "null"],
          "enum": ["Sole", "Lead", "Equal", "Support", null]
        },
        "tool": {
          "description": "AI tool or service used by this contributor for this role (e.g. 'ChatGPT', 'Claude Sonnet 4.5'). May be empty if no AI was used.",
          "type": ["string", "null"]
        },
        "reason": {
          "description": "Audit-trail note — short free text describing how the AI was used and what review was performed. Recommended whenever extent > 0.",
          "type": ["string", "null"]
        },
        "extent": {
          "description": "Extent of AI use by this contributor on this role. 0 = no AI; 1 = some AI use; 2 = extensive AI use. Half-steps (0.5, 1.5) may appear in legacy files and are accepted on load.",
          "type": "number",
          "minimum": 0,
          "maximum": 2,
          "multipleOf": 0.5
        }
      }
    },

    "roleData": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contributors": {
          "description": "Ordered list of contributors who worked on this role. May be empty if the role was filled in at row level only or skipped.",
          "type": "array",
          "items": { "$ref": "#/$defs/contributor" }
        },
        "tool": {
          "description": "Row-level AI tool fallback used when 'contributors' is empty. Otherwise informational only — per-contributor 'tool' is the source of truth in the figure and exports.",
          "type": ["string", "null"]
        },
        "reason": {
          "description": "Row-level audit-trail note. Used when 'contributors' is empty; otherwise contributor-level notes take precedence.",
          "type": ["string", "null"]
        },
        "extent": {
          "description": "Row-level AI extent. When contributors are listed this is computed from them on render; when the row is filled at row level only, this is the authoritative value.",
          "type": "number",
          "minimum": 0,
          "maximum": 2,
          "multipleOf": 0.5
        },
        "skipped": {
          "description": "True when the user has explicitly hidden this role from the table and figure. Skipped roles do not appear in exports.",
          "type": "boolean"
        }
      }
    },

    "portfolioEntry": {
      "type": "object",
      "required": ["id", "name", "data", "roles", "taxonomyMode"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "description": "Local identifier for this portfolio entry (usually a millisecond timestamp). Unique within the file; collisions on load are auto-resolved by regenerating ids.",
          "type": ["integer", "string"]
        },
        "name": {
          "description": "User-supplied label for the entry (e.g. 'Paper draft, March 2026').",
          "type": "string"
        },
        "data": {
          "description": "Snapshot of the per-role data at the time the entry was added to the portfolio.",
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/roleData" }
        },
        "roles": {
          "description": "Snapshot of the active role list at the time the entry was added.",
          "type": "array",
          "items": { "$ref": "#/$defs/role" }
        },
        "taxonomyMode": {
          "description": "Which taxonomy mode this entry was captured under.",
          "type": "string",
          "enum": ["credit", "custom"]
        }
      }
    }
  }
}
