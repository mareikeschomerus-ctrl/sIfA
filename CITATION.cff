version: "1.3"
date-released: "2026-07-05"
license: Apache-2.0
repository-code: "https://github.com/mareikeschomerus-ctrl/sIfA"
url: "https://github.com/mareikeschomerus-ctrl/sIfA"
doi: 10.5281/zenodo.20285993
keywords:
  - AI disclosure
  - research integrity
  - CRediT
  - contributor roles
  - responsible AI
references:
